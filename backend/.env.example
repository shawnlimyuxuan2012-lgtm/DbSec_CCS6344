
# ─── Server ─────────────────────────────────────────────────────────
DB_SERVER=192.168.56.105
DB_PORT=1433
DB_NAME=SecureStudentDB
DB_ENCRYPT=false
DB_TRUST_CERT=true

# ─── Per-role SQL logins (match RBAC_complete.sql) ───────────────────
# Admin role  – full CRUD, no DDL
DB_USER_ADMIN=AppAdmin
DB_PASS_ADMIN=Admin@SecureDB2026!

# Lecturer role – manage own classes/assignments/exams, read students
DB_USER_LECTURER=AppLecturer
DB_PASS_LECTURER=Lecturer@SecureDB2026!

# Student role – submit work, read own grades
DB_USER_STUDENT=AppStudent
DB_PASS_STUDENT=Student@SecureDB2026!

# ─── JWT ─────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ─── File upload ─────────────────────────────────────────────────────
UPLOAD_PATH=./uploads

# ─── SQL Audit file path (used by adminController) ───────────────────
SQL_AUDIT_FILEPATH=C:\SQLAudits\*.sqlaudit
